{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ct-parser-benchmark/v1",
  "title": "CT parser benchmark manifest row",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "record_id",
    "pdf_sha256",
    "mode",
    "elapsed_s",
    "pages_per_min"
  ],
  "properties": {
    "schema_version": { "const": "ct-parser-benchmark/v1" },
    "run_id": { "type": "string" },
    "record_id": { "type": "string" },
    "created_at": { "type": "string" },
    "pdf_name": { "type": "string" },
    "pdf_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "pdf_pages": { "type": "integer", "minimum": 1 },
    "mode": { "type": "string" },
    "elapsed_s": { "type": "number", "minimum": 0 },
    "pages_per_min": { "type": "number", "minimum": 0 },
    "markdown_chars": { "type": "integer", "minimum": 0 },
    "picture_count": { "type": "integer", "minimum": 0 },
    "described_picture_count": { "type": "integer", "minimum": 0 },
    "table_count": { "type": "integer", "minimum": 0 },
    "pipe_ready_tables": { "type": "integer", "minimum": 0 },
    "max_cells_in_table": { "type": "integer", "minimum": 0 },
    "docling_version": { "type": ["string", "null"] },
    "gpu_name": { "type": ["string", "null"] },
    "options": { "type": "object" }
  },
  "additionalProperties": true
}
